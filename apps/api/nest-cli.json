{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "entryFile": "apps/api/src/main",
  "compilerOptions": {
    "tsConfigPath": "tsconfig.build.json",
    "assets": [
      { "include": "oauth/providers.json", "outDir": "dist/apps/api/src", "watchAssets": true }
    ]
  }
}
